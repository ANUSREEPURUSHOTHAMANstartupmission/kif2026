---
const pillars = [
  {
    title: "Artificial Intelligence",
    image: "/img/2026/p1.svg",
    description:
      "Explore how AI is changing businesses, industries and everyday life.",
    border: "#000000",
    bg: "#ffffff",
    titleColor: "#000000",
  },
  {
    title: "DeepTech",
    image: "/img/2026/p2.svg",
    description:
      "Discover robotics, drones, advanced technologies and future innovations.",
    border: "#1896D4",
    bg: "#ffffff",
    titleColor: "#1896D4",
  },
  {
    title: "Sustainability",
    image: "/img/2026/p3.svg",
    description:
      "Learn about climate solutions, green technologies and sustainable development.",
    border: "#4CAF50",
    bg: "#ffffff",
    titleColor: "#15803D",
  },
  {
    title: "Creative Economy",
    image: "/img/2026/p4.svg",
    description:
      "See how creativity, culture, design and technology come together.",
    border: "#DC2626",
    bg: "#ffffff",
    titleColor: "#DC2626",
  },
  {
    title: "FoodTech",
    image: "/img/2026/p5.svg",
    description:
      "Explore innovation in food, agriculture and sustainable food systems.",
    border: "#F59E0B",
    bg: "#ffffff",
    titleColor: "#F59E0B",
  },
];
---

<section class=" bg-white ">
  <div class="mx-auto px-5 lg:px-20  w-full">
        <div class="flex items-center justify-center pb-6">
            <span class="inline-block  text-black px-8 py-2 rounded-md text-2xl font-bold ">
                The Five Pillars
            </span>
        </div>


    <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-5" data-aos="fade-down" data-aos-duration="500" data-aos-offset="100">

      {pillars.map((pillar) => (
        <div
          class="group rounded-2xl border p-6 text-center transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl" 
          style={`border-color:${pillar.border};background:${pillar.bg};`}
        >
          <!-- Image -->
          <div class="flex justify-center">
            <img
              src={pillar.image}
              alt={pillar.title}
              class="h-36 object-contain transition duration-300 group-hover:scale-105"
            />
          </div>

          <!-- Title -->
          <h3
            class=" text-base font-semibold leading-tight pt-3"
            style={`color:${pillar.titleColor}`}
          >
            {pillar.title}
          </h3>

          <!-- Description -->
          <p class="mt-4 text-sm text-gray-600">
            {pillar.description}
          </p>
        </div>
      ))}

    </div>
  </div>
</section>

<style is:global>
    .card-gradient-ai {
  background: linear-gradient(180deg, #ffffff 0%, #f5f9ff 100%);
}

.card-gradient-red {
  background: linear-gradient(180deg, #ffffff 0%, #fff6f6 100%);
}

.card-gradient-green {
  background: linear-gradient(180deg, #ffffff 0%, #f5fff7 100%);
}

.card-gradient-yellow {
  background: linear-gradient(180deg, #ffffff 0%, #fffbf2 100%);
}

.kif-card {
  transition: all 0.35s ease;
}

.kif-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 18px 35px rgba(0, 0, 0, 0.08);
}
</style>