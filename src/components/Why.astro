---
const keralaStats = [
  {
    color: "text-red-500",
    text: "Kerala has one of India's leading startup ecosystems",
  },
  {
    color: "text-green-600",
    text: "80,000+ Jobs Created",
  },
  {
    color: "text-sky-500",
    text: "560+ Innovation & Entrepreneurship Development Centres (IEDCs)",
  },
  {
    color: "text-red-500",
    text: "9,500+ Startups Supported",
  },
  {
    color: "text-green-600",
    text: "₹7,500 Crore+ Funding Raised",
  },
  {
    color: "text-sky-500",
    text: "250+ International Partnerships",
  },
];

const benefits = ["Build brand visibility", "Connect with future talent", "Meet startups and founders", "Showcase products and services", "Support innovation and entrepreneurship", "Create meaningful business opportunities"];
---

<section class="py-20 bg-white">
  <div class="px-5 lg:px-20 mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
      <div class="relative overflow-hidden rounded-[28px] border border-[#E6DDD3] shadow-lg bg-contain" style="background:#FBF6EF;">
        <div class="md:absolute bottom-0 right-0">
          <img src="/img/2026/whykerala.svg" />
        </div>
        <div class="relative z-10 p-10">
          <h2 class="text-xl font-bold text-gray-900">Why Kerala ?</h2>

          <div class="mt-4 space-y-2">
            {
              keralaStats.map((item) => (
                <div class="flex gap-4 items-center ">
                  <div class={`text-3xl ${item.color}`}>✷</div>

                  <p class="text-sm  text-gray-800">{item.text}</p>
                </div>
              ))
            }
          </div>
        </div>
      </div>

      <div class="rounded-[28px] border border-gray-200 shadow-lg bg-white relative">
        <div class="h-full">
          <div class="p-10 flex flex-col">
            <h2 class="text-xl font-bold leading-tight">Partner With KIF 2026</h2>

            <p class="mt-4 text-gray-700">KIF offers a unique opportunity for organizations to engage with startups, innovators, students and industry leaders.</p>

            <h3 class="mt-4 font-semibold text-base">As a partner, you can:</h3>

            <div class="mt-4 space-y-2">
              {
                benefits.map((item) => (
                  <div class="flex gap-3">
                    <div class="w-5 h-5 rounded-full bg-green-500 text-white flex items-center justify-center text-xs mt-1">✓</div>

                    <p class="text-sm">{item}</p>
                  </div>
                ))
              }
            </div>

            <button class=" mt-6 w-fit bg-[#E53935] hover:bg-red-700 transition text-white px-7 py-3 rounded-lg font-semibold flex items-center gap-3">
              Partner with Us
              <span class="text-xl">→</span>
            </button>
          </div>
          <div class=" w-full h-full">
            <img src="/img/2026/partner.svg" class=" hidden md:flex md:absolute right-0 top-52 w-1/2" alt="Partner" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
