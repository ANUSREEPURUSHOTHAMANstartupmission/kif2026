	<script>
		import Plyr from "plyr";
		var player = new Plyr("#youtube_player", {
			controls: [],
			hideControls: true,
			// clickToPlay: false,
			resetOnEnd: true,
			youtube: {
				noCookie: true, // Use youtube-nocookie.com
				modestbranding: 1, // Hide YouTube logo
				rel: 0, // No related videos after playback
				showinfo: 0, // Hide video title
				iv_load_policy: 3, // Hide annotations
				disablekb: 1, // Disable keyboard controls
			},
		});

		document.addEventListener("DOMContentLoaded", function () {
			document.getElementById("youtube-main-px-5 lg:px-20")?.classList.remove("lg:h-[35rem]");
		});

		document.querySelector(".video-play-btn")?.addEventListener("click", function () {
			document.getElementById("youtube-px-5 lg:px-20")?.classList.remove("hidden");
			player.play();
			document.querySelector(".video-play-btn")?.classList.add("hidden");
			document.getElementById("youtube-main-px-5 lg:px-20")?.classList.add("bg-transparent");
			document.getElementById("youtube-main-px-5 lg:px-20")?.classList.add("lg:h-[35rem]");
		});

		player.on("pause", (event) => {
			const instance = event.detail.plyr;
			document.querySelector(".video-play-btn")?.classList.remove("hidden");
			document.getElementById("youtube-px-5 lg:px-20")?.classList.add("hidden");
			document.getElementById("youtube-main-px-5 lg:px-20")?.classList.remove("lg:h-[35rem]");
		});
	</script>

	<script>
		import { gsap } from "gsap";

		document.querySelector("#programs-grid")?.addEventListener("mousemove", (e) => {
			document
				.querySelector("#programs-grid")
				?.querySelectorAll(".pitem")
				.forEach((item) => {
					const rect = item.getBoundingClientRect();
					const dx = e.clientX - (rect.left + rect.width / 2);
					const dy = e.clientY - (rect.top + rect.height / 2);
					const distance = Math.sqrt(dx * dx + dy * dy);

					if (distance < 150) {
						// React if within 150px
						const angle = Math.atan2(dy, dx);
						const force = Math.min(200 / distance, 20);
						gsap.to(item, {
							x: Math.cos(angle) * -force * 20,
							y: Math.sin(angle) * -force * 20,
							ease: "power2.out",
							duration: 0.5,
						});
					}
				});
		});

		document.querySelector("#programs-grid")?.addEventListener("mouseleave", () => {
			gsap.to(".pitem", {
				x: 0,
				y: 0,
				ease: "elastic.out(1, 0.5)",
				duration: 1.5,
			});
		});
	</script>

	<script is:inline>
  document.querySelectorAll("a.page-scroll").forEach((anchor) => {
    anchor.addEventListener("click", function (e) {
      const href = anchor.getAttribute("href");
      const targetId = href.replace(/^\/?#/, "");
      const targetElement = document.getElementById(targetId);

      if (targetElement) {
        e.preventDefault();

        targetElement.scrollIntoView({ behavior: "smooth" });

        history.replaceState(null, null, window.location.pathname);
      }
    });
  });

  window.addEventListener("DOMContentLoaded", () => {
    const hash = window.location.hash;
    if (hash) {
      const targetId = hash.replace("#", "");
      const targetElement = document.getElementById(targetId);
      if (targetElement) {
        setTimeout(() => {
          targetElement.scrollIntoView({ behavior: "smooth" });
          history.replaceState(null, null, window.location.pathname);
        }, 100);
      }
    }
  });
</script>

